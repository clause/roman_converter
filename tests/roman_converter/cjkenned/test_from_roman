from types import ModuleType


def test_from_roman(impl: ModuleType):
    
    # Basic Case with reepetition 
    assert impl.from_roman("VIII" == 8)
    
    # Subtraction 
    assert impl.from_roman("IV") == 4
    assert impl.from_roman("IX") == 9
    
